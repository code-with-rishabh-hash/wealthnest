{
  "name": "wealthnest",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/web",
    "packages/api"
  ],
  "scripts": {
    "dev": "npm run dev -w @wealthnest/web",
    "build": "npm run build -w @wealthnest/web",
    "test": "npm run test -w @wealthnest/web",
    "test:coverage": "npm run test:coverage -w @wealthnest/web",
    "lint": "npm run lint -w @wealthnest/web",
    "typecheck": "tsc -b packages/shared packages/web",
    "preview": "npm run preview -w @wealthnest/web"
  }
}
